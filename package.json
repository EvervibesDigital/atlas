{
  "name": "atlas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "description": "ATLAS — AI That Learns, Acts & Scales. A modular, plugin-first AI Operating System.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "tsx packages/app/src/main.ts",
    "cycle": "tsx packages/app/src/main-cycle.ts",
    "status": "tsx packages/app/src/main-status.ts",
    "seed": "tsx packages/app/src/main-seed.ts",
    "vault:try": "tsx packages/app/src/main-vault.ts",
    "vault:reset": "tsx packages/app/src/main-vault.ts reset",
    "ui": "tsx packages/server/src/main.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
